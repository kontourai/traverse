{
  "name": "@kontourai/traverse",
  "version": "0.19.0",
  "description": "Schema-directed content extraction that produces provenance-bearing, review-ready extraction proposals in Survey's shape.",
  "license": "Apache-2.0",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kontourai/traverse.git"
  },
  "homepage": "https://github.com/kontourai/traverse#readme",
  "bugs": {
    "url": "https://github.com/kontourai/traverse/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/src/index.js",
    "./anthropic": {
      "types": "./dist/src/anthropic.d.ts",
      "default": "./dist/src/anthropic.js"
    },
    "./openai": {
      "types": "./dist/src/openai.d.ts",
      "default": "./dist/src/openai.js"
    },
    "./gemini": {
      "types": "./dist/src/gemini.d.ts",
      "default": "./dist/src/gemini.js"
    },
    "./fetch": {
      "types": "./dist/src/fetch/index.d.ts",
      "default": "./dist/src/fetch/index.js"
    }
  },
  "files": [
    "dist/src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "eval:grounded": "npm run build --silent && node evals/grounded-extraction/run.mjs",
    "verify": "npm run check:content-boundary && npm run check:decisions && npm run typecheck && npm test && npm run check:pack",
    "check:content-boundary": "node scripts/check-content-boundary.cjs",
    "check:decisions": "node scripts/check-decisions.cjs check",
    "gen:decisions-index": "node scripts/check-decisions.cjs gen-index",
    "freeze:adrs": "node scripts/freeze-adrs.mjs",
    "check:pack": "node scripts/check-package-contents.mjs"
  },
  "dependencies": {
    "@kontourai/forage": "^0.2.0",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.4"
  },
  "peerDependencies": {
    "@google/genai": ">=1.0.0",
    "@anthropic-ai/sdk": ">=0.20.0",
    "openai": ">=4.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@google/genai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@kontourai/survey": "^1.2.1",
    "@types/node": "^25.6.0",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22"
  }
}
